---
import BaseLayout from '../../layouts/BaseLayout.astro';
import guides from '../../data/guides.json';

const sortedGuides = [...guides].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const bestToolsGuides = sortedGuides.filter(g => g.type === 'best-tools');
const howToChooseGuides = sortedGuides.filter(g => g.type === 'how-to-choose');

function estimateReadingTime(content: string): number {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<BaseLayout
  title="Blog & Guides"
  description="Expert guides on choosing the best AI DevOps tools. In-depth comparisons, buying guides, and how-to articles for DevOps teams."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-2">Blog & Guides</h1>
      <p class="text-text-muted mb-4">{guides.length} guides to help you pick the right tools</p>

      <!-- Search & Filter -->
      <div class="flex flex-col sm:flex-row gap-3 mb-10">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="guide-search"
            placeholder="Search guides..."
            class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <select
          id="type-filter"
          class="px-4 py-2.5 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-primary/50"
        >
          <option value="">All Types</option>
          <option value="best-tools">Best Tools</option>
          <option value="how-to-choose">How to Choose</option>
        </select>
      </div>

      <p id="search-count" class="text-sm text-text-muted mb-4 hidden"></p>

      {guides.length === 0 && (
        <div class="text-center py-20">
          <p class="text-text-muted text-lg">No guides yet. Check back soon!</p>
        </div>
      )}

      {bestToolsGuides.length > 0 && (
        <div id="best-tools-section" class="mb-12">
          <h2 class="text-2xl font-bold mb-6">Best Tools</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {bestToolsGuides.map((guide) => (
              <a
                href={`/blog/${guide.slug}/`}
                class="guide-card bg-white border border-border rounded-xl p-6 hover:shadow-md transition-shadow group"
                data-title={guide.title.toLowerCase()}
                data-description={guide.description.toLowerCase()}
                data-category={guide.category.toLowerCase()}
                data-type={guide.type}
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-medium bg-primary/10 text-primary px-2 py-0.5 rounded-full">{guide.category}</span>
                  <span class="text-xs text-text-muted">{estimateReadingTime(guide.content)} min read</span>
                </div>
                <h3 class="font-semibold text-lg group-hover:text-primary transition-colors mb-2">{guide.title}</h3>
                <p class="text-sm text-text-muted line-clamp-2">{guide.description}</p>
                <p class="text-xs text-text-muted mt-3">{new Date(guide.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      {howToChooseGuides.length > 0 && (
        <div id="how-to-choose-section" class="mb-12">
          <h2 class="text-2xl font-bold mb-6">How to Choose</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {howToChooseGuides.map((guide) => (
              <a
                href={`/blog/${guide.slug}/`}
                class="guide-card bg-white border border-border rounded-xl p-6 hover:shadow-md transition-shadow group"
                data-title={guide.title.toLowerCase()}
                data-description={guide.description.toLowerCase()}
                data-category={guide.category.toLowerCase()}
                data-type={guide.type}
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-medium bg-accent/10 text-secondary px-2 py-0.5 rounded-full">{guide.category}</span>
                  <span class="text-xs text-text-muted">{estimateReadingTime(guide.content)} min read</span>
                </div>
                <h3 class="font-semibold text-lg group-hover:text-primary transition-colors mb-2">{guide.title}</h3>
                <p class="text-sm text-text-muted line-clamp-2">{guide.description}</p>
                <p class="text-xs text-text-muted mt-3">{new Date(guide.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <p id="no-results" class="hidden text-center text-text-muted py-12">No guides found matching your search.</p>

      <script>
        const searchInput = document.getElementById('guide-search');
        const typeFilter = document.getElementById('type-filter');
        const cards = document.querySelectorAll('.guide-card');
        const noResults = document.getElementById('no-results');
        const searchCount = document.getElementById('search-count');
        const bestToolsSection = document.getElementById('best-tools-section');
        const howToChooseSection = document.getElementById('how-to-choose-section');
        const total = cards.length;

        function filterGuides() {
          const query = searchInput.value.toLowerCase().trim();
          const type = typeFilter.value;
          let visible = 0;
          let bestToolsVisible = 0;
          let howToChooseVisible = 0;

          cards.forEach(card => {
            const matchesSearch = !query ||
              card.dataset.title.includes(query) ||
              card.dataset.description.includes(query) ||
              card.dataset.category.includes(query);
            const matchesType = !type || card.dataset.type === type;
            const show = matchesSearch && matchesType;
            card.style.display = show ? '' : 'none';
            if (show) {
              visible++;
              if (card.dataset.type === 'best-tools') bestToolsVisible++;
              if (card.dataset.type === 'how-to-choose') howToChooseVisible++;
            }
          });

          if (bestToolsSection) bestToolsSection.style.display = bestToolsVisible > 0 ? '' : 'none';
          if (howToChooseSection) howToChooseSection.style.display = howToChooseVisible > 0 ? '' : 'none';

          noResults.classList.toggle('hidden', visible > 0);

          if (query || type) {
            searchCount.textContent = `Showing ${visible} of ${total} guides`;
            searchCount.classList.remove('hidden');
          } else {
            searchCount.classList.add('hidden');
          }
        }

        searchInput?.addEventListener('input', filterGuides);
        typeFilter?.addEventListener('change', filterGuides);
      </script>
    </div>
  </section>
</BaseLayout>
