---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="py-32 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h1 class="text-6xl font-bold text-text-muted mb-4">404</h1>
      <p class="text-xl text-text-muted mb-8">This page doesn't exist.</p>
      <a href="/" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-block">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
