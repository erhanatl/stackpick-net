---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import comparisons from '../../data/comparisons.json';
import guides from '../../data/guides.json';
import { marked } from 'marked';

export function getStaticPaths() {
  return tools
    .filter(t => t.status === 'Published')
    .map(tool => ({
      params: { slug: tool.slug },
      props: { tool }
    }));
}

const { tool } = Astro.props;

const categorySlug: Record<string, string> = {
  'CI/CD': 'ci-cd',
  'Code Assistant': 'code-assistant',
  'Monitoring': 'monitoring',
  'Testing': 'testing',
  'Security': 'security',
  'IaC': 'iac',
  'AI Code Review': 'ai-code-review',
  'AIOps': 'aiops',
};

const allRelatedTools = tools.filter(t => t.category === tool.category && t.slug !== tool.slug && t.status === 'Published');
const relatedTools = [...allRelatedTools].sort((a, b) => a.tool_name.localeCompare(b.tool_name)).slice(0, 6);
const relatedComparisons = comparisons.filter(c => c.tools.includes(tool.slug));
const relatedGuides = guides.filter(g => g.category === tool.category);

const prosList = tool.pros.split(',').map((p: string) => p.trim());
const consList = tool.cons.split(',').map((c: string) => c.trim());

const faqs = [
  {
    question: `What is ${tool.tool_name}?`,
    answer: tool.short_description
  },
  {
    question: `How much does ${tool.tool_name} cost?`,
    answer: `${tool.tool_name} uses a ${tool.pricing_model.toLowerCase()} pricing model with plans starting at ${tool.starting_price}.`
  },
  {
    question: `What are the main advantages of ${tool.tool_name}?`,
    answer: `The key advantages of ${tool.tool_name} include: ${prosList.join('; ')}.`
  },
  {
    question: `What are the drawbacks of ${tool.tool_name}?`,
    answer: `Some limitations to consider: ${consList.join('; ')}.`
  },
  {
    question: `What category does ${tool.tool_name} belong to?`,
    answer: `${tool.tool_name} is a ${tool.category} tool developed by ${tool.vendor}.`
  }
];
---

<BaseLayout
  title={`${tool.tool_name} Review 2026 | Pricing, Pros & Cons`}
  description={`${tool.tool_name} by ${tool.vendor} — ${tool.short_description} Pricing: ${tool.starting_price} (${tool.pricing_model}).`}
>
  <article class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="text-sm text-text-muted mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <a href="/tools/" class="hover:text-primary">Tools</a>
        <span class="mx-2">/</span>
        <a href={`/category/${categorySlug[tool.category]}/`} class="hover:text-primary">{tool.category}</a>
        <span class="mx-2">/</span>
        <span class="text-text">{tool.tool_name}</span>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <h1 class="text-4xl font-bold mb-2">{tool.tool_name}</h1>
        <p class="text-lg text-text-muted">by {tool.vendor}</p>
      </header>

      <!-- Quick Info -->
      <div class="grid grid-cols-3 gap-4 mb-10">
        <div class="bg-surface rounded-lg p-4 text-center">
          <p class="text-sm text-text-muted">Category</p>
          <p class="font-semibold">{tool.category}</p>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <p class="text-sm text-text-muted">Pricing</p>
          <p class="font-semibold">{tool.pricing_model}</p>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <p class="text-sm text-text-muted">Starting Price</p>
          <p class="font-semibold">{tool.starting_price}</p>
        </div>
      </div>

      <!-- AI Generated Content -->
      {tool.content && (
        <section class="mb-10 prose prose-lg max-w-none" set:html={marked(tool.content)} />
      )}

      <!-- Description (fallback if no AI content) -->
      {!tool.content && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold mb-4">Overview</h2>
          <p class="text-lg leading-relaxed">{tool.short_description}</p>
        </section>
      )}

      <!-- Pros & Cons -->
      <section class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="bg-green-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-green-800 mb-4">Pros</h3>
          <ul class="space-y-2">
            {tool.pros.split(',').map((pro: string) => (
              <li class="flex items-start gap-2">
                <span class="text-success font-bold mt-0.5">+</span>
                <span>{pro.trim()}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-red-800 mb-4">Cons</h3>
          <ul class="space-y-2">
            {tool.cons.split(',').map((con: string) => (
              <li class="flex items-start gap-2">
                <span class="text-danger font-bold mt-0.5">-</span>
                <span>{con.trim()}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="bg-surface rounded-xl p-5 group">
              <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
                {faq.question}
                <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-text-muted">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related Comparisons -->
      {relatedComparisons.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold mb-4">{tool.tool_name} Comparisons</h2>
          <div class="space-y-3">
            {relatedComparisons.map((comp) => (
              <a href={`/compare/${comp.slug}/`} class="flex items-center gap-3 bg-white border border-border rounded-xl p-4 hover:shadow-md transition-shadow group">
                <span class="bg-primary/10 text-primary rounded-lg p-2 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </span>
                <div>
                  <h3 class="font-semibold group-hover:text-primary transition-colors">{comp.title}</h3>
                  <p class="text-sm text-text-muted">{comp.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Related Guides -->
      {relatedGuides.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold mb-4">{tool.category} Guides</h2>
          <div class="space-y-3">
            {relatedGuides.map((guide) => (
              <a href={`/blog/${guide.slug}/`} class="flex items-center gap-3 bg-white border border-border rounded-xl p-4 hover:shadow-md transition-shadow group">
                <span class={`rounded-lg p-2 shrink-0 ${guide.type === 'best-tools' ? 'bg-primary/10 text-primary' : 'bg-accent/10 text-secondary'}`}>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                </span>
                <div>
                  <div class="flex items-center gap-2">
                    <h3 class="font-semibold group-hover:text-primary transition-colors">{guide.title}</h3>
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${guide.type === 'best-tools' ? 'bg-primary/10 text-primary' : 'bg-accent/10 text-secondary'}`}>
                      {guide.type === 'best-tools' ? 'Best Tools' : 'How to Choose'}
                    </span>
                  </div>
                  <p class="text-sm text-text-muted">{guide.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      <div class="bg-surface rounded-xl p-8 text-center mb-10">
        <h3 class="text-xl font-bold mb-3">Try {tool.tool_name}</h3>
        <p class="text-text-muted mb-4">Starting at {tool.starting_price}</p>
        <a
          href={tool.affiliate_url || tool.website_url}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-block"
        >
          Visit Website
        </a>
      </div>

      <!-- Related Tools -->
      {relatedTools.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold">Other {tool.category} Tools</h2>
            {allRelatedTools.length > 6 && (
              <a href={`/category/${categorySlug[tool.category]}/`} class="text-primary hover:text-primary-dark font-medium text-sm">
                View all {allRelatedTools.length} tools &rarr;
              </a>
            )}
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            {relatedTools.map((related) => (
              <a href={`/tools/${related.slug}/`} class="bg-white border border-border rounded-lg p-4 hover:shadow-md transition-shadow">
                <h4 class="font-semibold">{related.tool_name}</h4>
                <p class="text-sm text-text-muted mt-1">{related.short_description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- JSON-LD: SoftwareApplication -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": tool.tool_name,
        "description": tool.short_description,
        "applicationCategory": "DeveloperApplication",
        "applicationSubCategory": tool.category,
        "operatingSystem": "Web",
        "url": tool.website_url,
        "provider": {
          "@type": "Organization",
          "name": tool.vendor
        },
        "offers": {
          "@type": "Offer",
          "price": tool.starting_price,
          "priceCurrency": "USD",
          "category": tool.pricing_model
        }
      })} />

      <!-- JSON-LD: FAQPage -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })} />

      <!-- JSON-LD: BreadcrumbList -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackpick.net/" },
          { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://stackpick.net/tools/" },
          { "@type": "ListItem", "position": 3, "name": tool.category, "item": `https://stackpick.net/category/${categorySlug[tool.category]}/` },
          { "@type": "ListItem", "position": 4, "name": tool.tool_name }
        ]
      })} />
    </div>
  </article>
</BaseLayout>
