---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import tools from '../data/tools.json';
import categories from '../data/categories.json';
import guides from '../data/guides.json';

const publishedTools = tools.filter(t => t.status === 'Published');
const comparisons = (await import('../data/comparisons.json')).default;
const latestGuides = [...guides]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

const categoryIcons: Record<string, string> = {
  'CI/CD': '🔄',
  'Code Assistant': '🤖',
  'Monitoring': '📊',
  'Testing': '🧪',
  'Security': '🛡️',
  'IaC': '🏗️',
  'AI Code Review': '🔍',
  'AIOps': '⚡',
};

function estimateReadingTime(content: string): number {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<BaseLayout
  title="Home"
  description="Compare the best AI tools for DevOps. Unbiased reviews, side-by-side comparisons, and expert picks for CI/CD, monitoring, security, and more."
>
  <!-- Hero Section -->
  <section class="hero-gradient text-white py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(6,182,212,0.15),_transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(37,99,235,0.1),_transparent_60%)]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <div class="animate-fade-up">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight">
          Pick the Right AI Tools<br />
          <span class="bg-gradient-to-r from-accent to-blue-400 bg-clip-text text-transparent">for Your DevOps Stack</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 max-w-3xl mx-auto mb-8">
          Independent, unbiased comparisons of AI-powered DevOps tools.
          Side-by-side reviews to help your team make the right choice.
        </p>

        <!-- Hero Search -->
        <div class="max-w-2xl mx-auto mb-8">
          <a href="/tools/" class="flex items-center gap-3 w-full px-5 py-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/15 transition-all group cursor-text">
            <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="text-gray-400 text-sm md:text-base flex-1 text-left">Search {publishedTools.length} AI DevOps tools...</span>
            <span class="text-xs text-gray-500 bg-white/10 px-2 py-1 rounded shrink-0">Browse all →</span>
          </a>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/tools/" class="bg-primary hover:bg-primary-dark text-white px-8 py-3.5 rounded-lg font-semibold transition-all hover:shadow-lg hover:shadow-primary/25">
            Browse All Tools
          </a>
          <a href="/compare/" class="bg-white/10 hover:bg-white/20 text-white px-8 py-3.5 rounded-lg font-semibold transition-all border border-white/20 backdrop-blur-sm">
            Compare Tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white border-b border-border -mt-6 relative z-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-xl shadow-lg border border-border grid grid-cols-3 divide-x divide-border py-6">
        <a href="/tools/" class="text-center hover:bg-surface transition-colors rounded-l-xl py-2">
          <p class="text-2xl md:text-3xl font-bold text-primary">{publishedTools.length}</p>
          <p class="text-sm text-text-muted mt-1">AI Tools</p>
        </a>
        <a href="/compare/" class="text-center hover:bg-surface transition-colors py-2">
          <p class="text-2xl md:text-3xl font-bold text-primary">{comparisons.length}</p>
          <p class="text-sm text-text-muted mt-1">Comparisons</p>
        </a>
        <a href="/tools/" class="text-center hover:bg-surface transition-colors rounded-r-xl py-2">
          <p class="text-2xl md:text-3xl font-bold text-primary">{categories.length}</p>
          <p class="text-sm text-text-muted mt-1">Categories</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-16 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-center mb-2">Browse by Category</h2>
      <p class="text-text-muted text-center mb-10">Find the best AI tools for every part of your DevOps pipeline</p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {categories.map((cat) => {
          const toolCount = publishedTools.filter(t => t.category === cat.name).length;
          const icon = categoryIcons[cat.name] || '📦';
          return (
            <a href={`/category/${cat.slug}/`} class="card-hover bg-white rounded-xl p-5 text-center border border-border group">
              <span class="text-2xl mb-2 block">{icon}</span>
              <h3 class="font-semibold group-hover:text-primary transition-colors">{cat.name}</h3>
              <p class="text-sm text-text-muted mt-1">{toolCount} tools</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured Tools Section -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl font-bold">Featured Tools</h2>
        <a href="/tools/" class="text-primary hover:text-primary-dark font-medium text-sm">View all &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {publishedTools.filter(t => ['github-copilot', 'datadog-ai', 'snyk'].includes(t.slug)).map((tool) => (
          <ToolCard
            name={tool.tool_name}
            slug={tool.slug}
            category={tool.category}
            shortDescription={tool.short_description}
            vendor={tool.vendor}
            pricingModel={tool.pricing_model}
            startingPrice={tool.starting_price}
            websiteUrl={tool.website_url}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-primary to-blue-700 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(255,255,255,0.1),_transparent_50%)]"></div>
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <h2 class="text-3xl font-bold mb-4">Can't decide? Compare side by side</h2>
      <p class="text-lg text-blue-100 mb-8">
        See how tools stack up against each other with our detailed comparison pages.
      </p>
      <a href="/compare/" class="bg-white text-primary hover:bg-blue-50 px-8 py-3.5 rounded-lg font-semibold transition-all hover:shadow-lg inline-block">
        View Comparisons
      </a>
    </div>
  </section>

  <!-- Latest Guides Section -->
  {latestGuides.length > 0 && (
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
          <h2 class="text-2xl font-bold">Latest Guides</h2>
          <a href="/blog/" class="text-primary hover:text-primary-dark font-medium text-sm">View all &rarr;</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestGuides.map((guide) => (
            <a href={`/blog/${guide.slug}/`} class="card-hover bg-white border border-border rounded-xl p-6 group">
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${guide.type === 'best-tools' ? 'bg-primary/10 text-primary' : 'bg-accent/10 text-secondary'}`}>
                  {guide.type === 'best-tools' ? 'Best Tools' : 'How to Choose'}
                </span>
                <span class="text-xs text-text-muted">{estimateReadingTime(guide.content)} min read</span>
              </div>
              <h3 class="font-semibold text-lg group-hover:text-primary transition-colors mb-2">{guide.title}</h3>
              <p class="text-sm text-text-muted line-clamp-2">{guide.description}</p>
              <p class="text-xs text-text-muted mt-3">{new Date(guide.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Suggest Tool Section -->
  <section class="py-16 bg-surface">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Know a tool we're missing?</h2>
      <p class="text-lg text-text-muted mb-8">
        Help us build the best DevOps AI tools directory. Suggest a tool and we'll review it.
      </p>
      <a href="/suggest/" class="bg-secondary hover:bg-slate-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-block">
        Suggest a Tool
      </a>
    </div>
  </section>
</BaseLayout>
