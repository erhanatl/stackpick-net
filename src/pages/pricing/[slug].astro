---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import { marked } from 'marked';

export function getStaticPaths() {
  return tools
    .filter(t => t.status === 'Published')
    .map(tool => ({
      params: { slug: tool.slug },
      props: { tool }
    }));
}

const { tool } = Astro.props;

const categorySlug: Record<string, string> = {
  'CI/CD': 'ci-cd',
  'Code Assistant': 'code-assistant',
  'Monitoring': 'monitoring',
  'Testing': 'testing',
  'Security': 'security',
  'IaC': 'iac',
  'AI Code Review': 'ai-code-review',
  'AIOps': 'aiops',
};

const getDomain = (url: string | undefined) => {
  if (!url) return null;
  try { return new URL(url).hostname; } catch { return null; }
};

const toolDomain = getDomain(tool.website_url);
const toolLogo = toolDomain ? `https://www.google.com/s2/favicons?domain=${toolDomain}&sz=64` : null;

// Same category tools for comparison
const categoryTools = tools
  .filter(t => t.category === tool.category && t.slug !== tool.slug && t.status === 'Published')
  .sort((a, b) => a.tool_name.localeCompare(b.tool_name));

const pricingColors: Record<string, { bg: string; text: string; label: string }> = {
  'Free': { bg: 'bg-green-50 border-green-200', text: 'text-green-700', label: 'Completely Free' },
  'Freemium': { bg: 'bg-blue-50 border-blue-200', text: 'text-blue-700', label: 'Free Tier Available' },
  'Paid': { bg: 'bg-orange-50 border-orange-200', text: 'text-orange-700', label: 'Paid Only' },
  'Enterprise': { bg: 'bg-purple-50 border-purple-200', text: 'text-purple-700', label: 'Enterprise Pricing' },
  'Open Source': { bg: 'bg-emerald-50 border-emerald-200', text: 'text-emerald-700', label: 'Open Source' },
};

const pricingStyle = pricingColors[tool.pricing_model] || { bg: 'bg-gray-50 border-gray-200', text: 'text-gray-700', label: tool.pricing_model };

const pricingContent = (tool as any).pricing_content || '';

const faqs = [
  {
    question: `How much does ${tool.tool_name} cost?`,
    answer: `${tool.tool_name} uses a ${tool.pricing_model.toLowerCase()} pricing model. Plans start at ${tool.starting_price}.`
  },
  {
    question: `Does ${tool.tool_name} have a free plan?`,
    answer: tool.pricing_model === 'Free' || tool.pricing_model === 'Open Source'
      ? `Yes, ${tool.tool_name} is completely free to use.`
      : tool.pricing_model === 'Freemium'
        ? `Yes, ${tool.tool_name} offers a free tier with limited features. Paid plans start at ${tool.starting_price}.`
        : `No, ${tool.tool_name} does not offer a free plan. Pricing starts at ${tool.starting_price}.`
  },
  {
    question: `Is ${tool.tool_name} worth the price?`,
    answer: `${tool.tool_name} offers ${tool.pros.split(',').slice(0, 2).map((p: string) => p.trim().toLowerCase()).join(' and ')}. However, consider that ${tool.cons.split(',')[0].trim().toLowerCase()}. Compare with alternatives to find the best value for your needs.`
  },
  {
    question: `What are cheaper alternatives to ${tool.tool_name}?`,
    answer: `Check our alternatives page for ${tool.tool_name} to find more affordable options in the ${tool.category} category.`
  }
];
---

<BaseLayout
  title={`${tool.tool_name} Pricing 2026 | Plans, Cost & Free Tier`}
  description={`${tool.tool_name} pricing breakdown for 2026. ${pricingStyle.label} — starting at ${tool.starting_price}. Compare plans and find the best value for your ${tool.category.toLowerCase()} needs.`}
>
  <article class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="text-sm text-text-muted mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <a href="/tools/" class="hover:text-primary">Tools</a>
        <span class="mx-2">/</span>
        <a href={`/tools/${tool.slug}/`} class="hover:text-primary">{tool.tool_name}</a>
        <span class="mx-2">/</span>
        <span class="text-text">Pricing</span>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex items-center gap-4 mb-4">
          {toolLogo ? (
            <img src={toolLogo} alt={`${tool.tool_name} logo`} width="48" height="48" class="rounded-lg shrink-0" loading="lazy" />
          ) : (
            <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center shrink-0">
              <span class="text-xl font-bold text-gray-400">{tool.tool_name.charAt(0)}</span>
            </div>
          )}
          <div>
            <h1 class="text-3xl md:text-4xl font-bold">{tool.tool_name} Pricing</h1>
            <p class="text-text-muted mt-1">Plans and cost breakdown for 2026</p>
          </div>
        </div>
      </header>

      <!-- Pricing Highlight -->
      <div class={`rounded-xl p-6 mb-10 border-2 ${pricingStyle.bg}`}>
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <span class={`text-sm font-semibold uppercase tracking-wide ${pricingStyle.text}`}>{pricingStyle.label}</span>
            <div class="mt-2">
              <span class="text-4xl font-bold text-secondary">{tool.starting_price}</span>
            </div>
            <p class="text-text-muted mt-1">by {tool.vendor} · {tool.category}</p>
          </div>
          <div class="flex flex-col gap-2">
            <a
              href={tool.affiliate_url || tool.website_url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors text-center"
            >
              View Official Pricing
            </a>
            <a href={`/tools/${tool.slug}/`} class="text-primary hover:text-primary-dark text-sm font-medium text-center">
              Read full review &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- AI Generated Pricing Content -->
      {pricingContent && (
        <section class="mb-10 prose prose-lg max-w-none" set:html={marked(pricingContent)} />
      )}

      <!-- Value Assessment -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-6">Is {tool.tool_name} Worth It?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-green-50 rounded-xl p-6">
            <h3 class="text-lg font-bold text-green-800 mb-4">What You Get</h3>
            <ul class="space-y-2">
              {tool.pros.split(',').map((pro: string) => (
                <li class="flex items-start gap-2">
                  <span class="text-success font-bold mt-0.5 shrink-0">+</span>
                  <span>{pro.trim()}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-red-50 rounded-xl p-6">
            <h3 class="text-lg font-bold text-red-800 mb-4">What to Watch Out For</h3>
            <ul class="space-y-2">
              {tool.cons.split(',').map((con: string) => (
                <li class="flex items-start gap-2">
                  <span class="text-danger font-bold mt-0.5 shrink-0">-</span>
                  <span>{con.trim()}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Price Comparison with Category Tools -->
      {categoryTools.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold mb-6">{tool.category} Pricing Comparison</h2>
          <div class="overflow-x-auto">
            <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm text-sm">
              <thead>
                <tr class="bg-secondary text-white">
                  <th class="text-left p-3 font-semibold">Tool</th>
                  <th class="text-center p-3 font-semibold">Pricing Model</th>
                  <th class="text-center p-3 font-semibold">Starting Price</th>
                  <th class="text-center p-3 font-semibold">Vendor</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border">
                <tr class="bg-primary/5">
                  <td class="p-3 font-semibold">
                    <a href={`/tools/${tool.slug}/`} class="hover:text-primary">{tool.tool_name}</a>
                    <span class="text-xs text-text-muted ml-1">(this tool)</span>
                  </td>
                  <td class="p-3 text-center">
                    <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full ${pricingColors[tool.pricing_model]?.bg || 'bg-gray-100'} ${pricingColors[tool.pricing_model]?.text || 'text-gray-700'}`}>
                      {tool.pricing_model}
                    </span>
                  </td>
                  <td class="p-3 text-center font-semibold">{tool.starting_price}</td>
                  <td class="p-3 text-center">{tool.vendor}</td>
                </tr>
                {categoryTools.slice(0, 10).map((t) => (
                  <tr>
                    <td class="p-3 font-semibold">
                      <a href={`/pricing/${t.slug}/`} class="hover:text-primary">{t.tool_name}</a>
                    </td>
                    <td class="p-3 text-center">
                      <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full ${pricingColors[t.pricing_model]?.bg || 'bg-gray-100'} ${pricingColors[t.pricing_model]?.text || 'text-gray-700'}`}>
                        {t.pricing_model}
                      </span>
                    </td>
                    <td class="p-3 text-center font-medium">{t.starting_price}</td>
                    <td class="p-3 text-center">{t.vendor}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {categoryTools.length > 10 && (
            <p class="text-sm text-text-muted mt-3 text-center">
              <a href={`/category/${categorySlug[tool.category]}/`} class="text-primary hover:text-primary-dark font-medium">
                View all {categoryTools.length + 1} {tool.category} tools &rarr;
              </a>
            </p>
          )}
        </section>
      )}

      <!-- FAQ -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-6">Pricing FAQ</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="bg-surface rounded-xl p-5 group">
              <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
                {faq.question}
                <svg class="w-5 h-5 text-text-muted transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="mt-3 text-text-muted">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTAs -->
      <div class="bg-surface rounded-xl p-8 text-center">
        <h3 class="text-xl font-bold mb-3">Not sure about {tool.tool_name}?</h3>
        <p class="text-text-muted mb-6">Explore alternatives or compare with other tools.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={`/alternatives/${tool.slug}/`} class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-block">
            View Alternatives
          </a>
          <a href="/compare/" class="bg-white hover:bg-gray-50 text-secondary border border-border px-8 py-3 rounded-lg font-semibold transition-colors inline-block">
            Compare Tools
          </a>
        </div>
      </div>

      <!-- JSON-LD: FAQPage -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })} />

      <!-- JSON-LD: BreadcrumbList -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://stackpick.net/" },
          { "@type": "ListItem", "position": 2, "name": "Tools", "item": "https://stackpick.net/tools/" },
          { "@type": "ListItem", "position": 3, "name": tool.tool_name, "item": `https://stackpick.net/tools/${tool.slug}/` },
          { "@type": "ListItem", "position": 4, "name": "Pricing" }
        ]
      })} />
    </div>
  </article>
</BaseLayout>
