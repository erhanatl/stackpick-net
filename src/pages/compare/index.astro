---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';
import comparisons from '../../data/comparisons.json';

const publishedTools = tools.filter(t => t.status === 'Published');
const categories = [...new Set(publishedTools.map(t => t.category))].sort();
---

<BaseLayout
  title="AI DevOps Tool Comparisons"
  description="Side-by-side comparisons of the best AI tools for DevOps. Compare features, pricing, and pros/cons to find the right tools for your team."
>
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-4">Compare Tools</h1>
      <p class="text-lg text-text-muted mb-10">Select a category and pick 2-3 tools to compare side by side.</p>

      <!-- Step 1: Category Selection -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold mb-3">1. Choose a Category</h2>
        <div class="flex flex-wrap gap-3" id="category-buttons">
          {categories.map((cat) => (
            <button
              data-category={cat}
              class="category-btn px-5 py-2.5 rounded-lg border border-border bg-white text-sm font-medium hover:border-primary hover:text-primary transition-colors"
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Step 2: Tool Selection -->
      <div class="mb-8 hidden" id="tool-selection">
        <h2 class="text-lg font-semibold mb-3">2. Pick 2-3 Tools</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3" id="tool-buttons">
        </div>
        <p class="text-sm text-text-muted mt-2" id="selection-hint">Select at least 2 tools to compare.</p>
      </div>

      <!-- Step 3: Compare Button -->
      <div class="mb-10 hidden" id="compare-action">
        <button
          id="compare-btn"
          class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors"
        >
          Compare Selected Tools
        </button>
      </div>

      <!-- Comparison Result -->
      <div class="hidden" id="comparison-result">
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm" id="comparison-table">
          </table>
        </div>
      </div>

      <!-- Divider -->
      <div class="border-t border-border my-12" id="featured-divider"></div>

      <!-- Featured Comparisons -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Featured Comparisons</h2>
        <div class="space-y-4">
          {comparisons.map((comp) => (
            <a href={`/compare/${comp.slug}/`} class="block bg-white border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold mb-2">{comp.title}</h3>
              <p class="text-text-muted">{comp.description}</p>
              <span class="inline-block mt-4 text-primary font-medium text-sm">Read detailed comparison &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Tools data for JavaScript -->
  <script define:vars={{ publishedTools }}>
    const allTools = publishedTools;
    let selectedCategory = null;
    let selectedTools = [];

    // Category click
    document.querySelectorAll('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedCategory = btn.dataset.category;
        selectedTools = [];

        // Highlight active category
        document.querySelectorAll('.category-btn').forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('bg-white');
        });
        btn.classList.add('bg-primary', 'text-white', 'border-primary');
        btn.classList.remove('bg-white');

        // Show tools for category
        const categoryTools = allTools.filter(t => t.category === selectedCategory);
        const toolButtons = document.getElementById('tool-buttons');
        toolButtons.innerHTML = categoryTools.map(t => {
          const domain = t.website_url ? new URL(t.website_url).hostname : null;
          const logoHtml = domain
            ? `<img src="https://www.google.com/s2/favicons?domain=${domain}&sz=32" alt="" width="20" height="20" class="rounded shrink-0" loading="lazy">`
            : `<span class="w-5 h-5 rounded bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-400 shrink-0">${t.tool_name.charAt(0)}</span>`;
          return `
            <button
              data-slug="${t.slug}"
              class="tool-btn px-4 py-3 rounded-lg border border-border bg-white text-left hover:border-primary transition-colors"
            >
              <div class="flex items-center gap-2">
                ${logoHtml}
                <div>
                  <span class="font-medium text-sm">${t.tool_name}</span>
                  <span class="block text-xs text-gray-500 mt-0.5">${t.vendor}</span>
                </div>
              </div>
            </button>
          `;
        }).join('');

        // Add click listeners to tool buttons
        toolButtons.querySelectorAll('.tool-btn').forEach(tbtn => {
          tbtn.addEventListener('click', () => toggleTool(tbtn));
        });

        document.getElementById('tool-selection').classList.remove('hidden');
        document.getElementById('compare-action').classList.add('hidden');
        document.getElementById('comparison-result').classList.add('hidden');
        updateSelectionHint();
      });
    });

    function toggleTool(btn) {
      const slug = btn.dataset.slug;

      if (selectedTools.includes(slug)) {
        selectedTools = selectedTools.filter(s => s !== slug);
        btn.classList.remove('bg-primary', 'text-white', 'border-primary');
        btn.classList.add('bg-white');
      } else if (selectedTools.length < 3) {
        selectedTools.push(slug);
        btn.classList.add('bg-primary', 'text-white', 'border-primary');
        btn.classList.remove('bg-white');
      }

      updateSelectionHint();

      if (selectedTools.length >= 2) {
        document.getElementById('compare-action').classList.remove('hidden');
      } else {
        document.getElementById('compare-action').classList.add('hidden');
      }
    }

    function updateSelectionHint() {
      const hint = document.getElementById('selection-hint');
      const remaining = 2 - selectedTools.length;
      if (remaining > 0) {
        hint.textContent = `Select ${remaining} more tool${remaining > 1 ? 's' : ''} to compare.`;
      } else if (selectedTools.length === 2) {
        hint.textContent = 'You can select 1 more tool, or compare now.';
      } else {
        hint.textContent = 'Maximum 3 tools selected. Click "Compare" to see results.';
      }
    }

    // Compare button
    document.getElementById('compare-btn').addEventListener('click', () => {
      const selected = selectedTools.map(slug => allTools.find(t => t.slug === slug));

      const headers = selected.map(t => {
        const d = t.website_url ? new URL(t.website_url).hostname : null;
        const logo = d ? `<img src="https://www.google.com/s2/favicons?domain=${d}&sz=32" alt="" width="20" height="20" class="rounded inline-block mr-1 align-middle">` : '';
        return `<th class="text-center p-4 font-semibold"><a href="/tools/${t.slug}/" class="hover:text-cyan-400 transition-colors">${logo}${t.tool_name}</a></th>`;
      }).join('');

      const pricingRow = selected.map(t =>
        `<td class="p-4 text-center">${t.pricing_model}</td>`
      ).join('');

      const priceRow = selected.map(t =>
        `<td class="p-4 text-center font-semibold">${t.starting_price}</td>`
      ).join('');

      const prosRow = selected.map(t => {
        const items = t.pros.split(',').map(p =>
          `<li class="flex items-start gap-1"><span class="text-green-500 mt-0.5">+</span><span>${p.trim()}</span></li>`
        ).join('');
        return `<td class="p-4 text-sm"><ul class="space-y-1">${items}</ul></td>`;
      }).join('');

      const consRow = selected.map(t => {
        const items = t.cons.split(',').map(c =>
          `<li class="flex items-start gap-1"><span class="text-red-500 mt-0.5">-</span><span>${c.trim()}</span></li>`
        ).join('');
        return `<td class="p-4 text-sm"><ul class="space-y-1">${items}</ul></td>`;
      }).join('');

      const ctaRow = selected.map(t =>
        `<td class="p-4 text-center"><a href="${t.affiliate_url || t.website_url}" target="_blank" rel="noopener noreferrer" class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">Visit Website</a></td>`
      ).join('');

      document.getElementById('comparison-table').innerHTML = `
        <thead>
          <tr class="bg-slate-900 text-white">
            <th class="text-left p-4 font-semibold">Feature</th>
            ${headers}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <tr class="bg-slate-50">
            <td class="p-4 font-medium">Pricing Model</td>
            ${pricingRow}
          </tr>
          <tr>
            <td class="p-4 font-medium">Starting Price</td>
            ${priceRow}
          </tr>
          <tr class="bg-slate-50">
            <td class="p-4 font-medium">Pros</td>
            ${prosRow}
          </tr>
          <tr>
            <td class="p-4 font-medium">Cons</td>
            ${consRow}
          </tr>
          <tr class="bg-slate-50">
            <td class="p-4 font-medium">Try It</td>
            ${ctaRow}
          </tr>
        </tbody>
      `;

      document.getElementById('comparison-result').classList.remove('hidden');
      document.getElementById('comparison-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</BaseLayout>
