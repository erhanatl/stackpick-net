---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import tools from '../../data/tools.json';
import comparisons from '../../data/comparisons.json';
import { marked } from 'marked';

export function getStaticPaths() {
  return comparisons.map(comp => ({
    params: { slug: comp.slug },
    props: { comparison: comp }
  }));
}

const { comparison } = Astro.props;
const comparedTools = comparison.tools
  .map((slug: string) => tools.find(t => t.slug === slug))
  .filter(Boolean) as typeof tools;

const toolNames = comparedTools.map(t => t.tool_name).join(' vs ');
---

<BaseLayout
  title={`${toolNames} (2026)`}
  description={comparison.description}
>
  <article class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="text-sm text-text-muted mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <a href="/compare/" class="hover:text-primary">Comparisons</a>
        <span class="mx-2">/</span>
        <span class="text-text">{toolNames}</span>
      </nav>

      <h1 class="text-4xl font-bold mb-4">{toolNames} (2026)</h1>
      <p class="text-lg text-text-muted mb-10">{comparison.description}</p>

      <!-- Comparison Table -->
      <ComparisonTable tools={comparedTools.map(t => ({
        name: t.tool_name,
        slug: t.slug,
        pricingModel: t.pricing_model,
        startingPrice: t.starting_price,
        pros: t.pros,
        cons: t.cons
      }))} />

      <!-- AI Generated Content -->
      {comparison.content && (
        <section class="mt-12 prose prose-lg max-w-none" set:html={marked(comparison.content)} />
      )}

      <!-- CTA -->
      <div class="grid md:grid-cols-2 gap-6 mt-10">
        {comparedTools.map((tool) => (
          <div class="bg-white border border-border rounded-xl p-6 text-center">
            <h3 class="text-lg font-bold mb-2">{tool.tool_name}</h3>
            <p class="text-text-muted text-sm mb-4">{tool.starting_price} · {tool.pricing_model}</p>
            <a
              href={tool.affiliate_url || tool.website_url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-primary hover:bg-primary-dark text-white px-6 py-2 rounded-lg font-semibold transition-colors inline-block text-sm"
            >
              Try {tool.tool_name}
            </a>
          </div>
        ))}
      </div>

      <!-- JSON-LD -->
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": `${toolNames} Comparison 2026`,
        "description": comparison.description,
        "datePublished": "2026-03-20",
        "author": {
          "@type": "Organization",
          "name": "Stackpick"
        }
      })} />
    </div>
  </article>
</BaseLayout>
