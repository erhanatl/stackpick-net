---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Thanks for suggesting a tool!"
  noindex={true}
>
  <section class="py-24">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="text-6xl mb-6">&#10003;</div>
      <h1 class="text-3xl font-bold mb-4">Thanks for your suggestion!</h1>
      <p class="text-text-muted text-lg mb-8">
        We'll review your tool suggestion and add it to Stackpick if it fits our DevOps AI tools coverage.
      </p>
      <a href="/" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-block">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
